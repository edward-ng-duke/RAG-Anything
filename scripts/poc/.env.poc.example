# Copy this file to `.env.poc` (in the same directory), fill in real values,
# then from the repo root run:
#   python scripts/poc/poc_ingest_query.py
#
# All eight variables below are REQUIRED. The script exits with code 2 and
# lists missing keys if any are blank or absent.

# --- LLM (OpenAI-compatible chat completions) ---
LLM_BASE_URL=https://api.example.com/v1
LLM_API_KEY=sk-replace-me
LLM_MODEL=qwen-plus

# --- Embedding (OpenAI-compatible /embeddings) ---
EMBEDDING_BASE_URL=https://api.example.com/v1
EMBEDDING_API_KEY=sk-replace-me
EMBEDDING_MODEL=text-embedding-v2

# --- MinerU Cloud (https://mineru.net) ---
MINERU_CLOUD_API_KEY=replace-me

# --- Postgres (LightRAG PG backend: KV / vector / graph / docstatus) ---
# Form: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
POSTGRES_DSN=postgresql://rag:rag@localhost:5432/rag

# --- Optional knobs (uncomment to override defaults) ---
# EMBEDDING_DIM=1536
# MINERU_POLL_INTERVAL_SEC=5
# MINERU_POLL_TIMEOUT_SEC=900
