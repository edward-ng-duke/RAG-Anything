# Example environment file for the rag_service backend.
# Copy to `.env` and fill in real values. All entries are commented out
# so this file is safe to commit.

# ---- Required ----
# Dev compose publishes pg on host :5532 and redis on host :6479 (shifted to
# coexist with onyx's dev stack which uses 5432/6379). For host-based dev
# (`uv run rag-api`), match those ports here.
# DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5532/rag
# REDIS_URL=redis://localhost:6479/0
# INTERNAL_TOKEN=replace-with-a-long-random-string
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-replace-me
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-replace-me
# EMBEDDING_MODEL=text-embedding-3-small

# ---- Optional ----
# VLM_MODEL=
# MINERU_CLOUD_API_KEY=
# PARSER_MODE=mineru_cloud          # one of: mineru_cloud | local_gpu
# DATA_DIR=./data
# MAX_UPLOAD_MB=1000
# LRU_INSTANCE_CAP=32

# ---- ONYX integration (optional; only needed if exposing /v1/onyx/* to the ONYX backend) ----
# INTERNAL_TOKEN  is the service-to-service shared secret. ≥64 chars; the
# above value already covers it. Generate via: openssl rand -hex 48
#
# INTERNAL_TOKENS_LEGACY accepts a comma-separated list of older tokens
# during a key rotation. Each entry must also be ≥64 chars. Empty/unset
# means single-token mode.
# INTERNAL_TOKENS_LEGACY=
#
# ONYX_BACKEND_ALLOWED_CIDRS restricts /v1/onyx/* to specific source IPs.
# Comma-separated CIDRs (v4 and/or v6). Empty/unset disables the gate
# (token-only auth).
# ONYX_BACKEND_ALLOWED_CIDRS=10.0.1.0/24,10.0.2.5/32
#
# ONYX_RATELIMIT_OVERRIDES_JSON lets ops adjust per-class limits without
# code changes. Whitelist keys: query, docs_post, kg, other, token_total.
# Window is fixed at 60 seconds. Empty/unset uses defaults
# (query=30, docs_post=10, kg=120, other=60, token_total=1000 per minute).
# ONYX_RATELIMIT_OVERRIDES_JSON={"query":60,"docs_post":20}
