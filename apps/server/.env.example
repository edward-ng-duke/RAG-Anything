# Example environment file for the rag_service backend.
# Copy to `.env` and fill in real values. All entries are commented out
# so this file is safe to commit.

# ---- Required ----
# DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/rag
# REDIS_URL=redis://localhost:6379/0
# INTERNAL_TOKEN=replace-with-a-long-random-string
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-replace-me
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-replace-me
# EMBEDDING_MODEL=text-embedding-3-small

# ---- Optional ----
# VLM_MODEL=
# MINERU_CLOUD_API_KEY=
# PARSER_MODE=mineru_cloud          # one of: mineru_cloud | local_gpu
# DATA_DIR=./data
# MAX_UPLOAD_MB=1000
# LRU_INSTANCE_CAP=32
